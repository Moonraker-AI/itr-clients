{
  "name": "itr-clients",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "smoke:pdf": "tsx scripts/render-sample.ts"
  },
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "^1.4.0",
    "@google-cloud/storage": "^7.19.0",
    "@hono/node-server": "^1.13.0",
    "@react-pdf/renderer": "^4.5.1",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
