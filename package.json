{
  "name": "itr-clients",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "scripts": {
    "dev": "npm run build:assets && npm run build:css && tsx watch src/server.ts",
    "build": "tsc -p . && npm run build:css && npm run build:assets",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./dist/static/app.css --minify",
    "build:assets": "node scripts/build-assets.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "smoke:pdf": "tsx scripts/render-sample.ts",
    "smoke:retreat": "tsx scripts/seed-smoke-retreat.ts",
    "test": "node --import tsx --test $(find tests -name '*.test.ts' -type f | sort)"
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/fira-code": "^5.2.7",
    "@google-cloud/cloud-sql-connector": "^1.4.0",
    "@google-cloud/storage": "^7.19.0",
    "@hono/node-server": "^1.13.0",
    "@react-pdf/renderer": "^4.5.1",
    "drizzle-orm": "^0.36.0",
    "firebase-admin": "^13.0.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "hono": "^4.6.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.2",
    "pg": "^8.13.0",
    "react": "^19.2.5",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
