# Local dev only. Copy to .env.local (gitignored) and fill in.
# Get the dev DB password:
#   gcloud secrets versions access latest --secret=db-url --project=itr-clients-dev

# When LOCAL_DB_URL is set, src/db/client.ts uses it directly.
# Use this with Cloud SQL Auth Proxy on 127.0.0.1:5432.
LOCAL_DB_URL=postgres://itr_app_user:REPLACE@127.0.0.1:5432/itr

# Used by drizzle-kit only (separate from runtime).
DEV_DB_URL=postgres://itr_app_user:REPLACE@127.0.0.1:5432/itr

PORT=8080
NODE_ENV=development
